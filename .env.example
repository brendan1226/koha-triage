# Required for AI recommendations, code generation, and verdict classification.
# Get one from https://console.anthropic.com/settings/keys
KOHA_TRIAGE_ANTHROPIC_API_KEY=

# Optional: GitHub token raises rate limits from 60/hr to 5000/hr when fetching
# Koha source files from the GitHub mirror for code generation.
# Only needs public_repo read scope.
KOHA_TRIAGE_GITHUB_TOKEN=

# Where to store the SQLite database. Default: ./data/koha-triage.db
# KOHA_TRIAGE_DB_PATH=./data/koha-triage.db

# Embedding model for semantic search. Default: BAAI/bge-small-en-v1.5 (384 dims, ~90MB).
# KOHA_TRIAGE_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Claude model for classification + recommendations. Default: claude-opus-4-6.
# KOHA_TRIAGE_CLASSIFICATION_MODEL=claude-opus-4-6

# Google OAuth (optional — leave blank to disable auth entirely).
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://your-domain.com/auth/callback
# KOHA_TRIAGE_GOOGLE_CLIENT_ID=
# KOHA_TRIAGE_GOOGLE_CLIENT_SECRET=

# Secret key for signing session cookies.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# KOHA_TRIAGE_SESSION_SECRET=change-me-in-production

# Comma-separated list of email domains allowed to log in.
# KOHA_TRIAGE_ALLOWED_DOMAINS=bywatersolutions.com
